
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all authenticated users full access to all collections
    // This simple rule is the most robust way to ensure collectionGroup queries work
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicitly authorize collection group queries for preaching_events and votes
    match /{path=**}/preaching_events/{event} {
      allow read, write: if request.auth != null;
    }

    match /{path=**}/votes/{vote} {
      allow read, write: if request.auth != null;
    }
  }
}
