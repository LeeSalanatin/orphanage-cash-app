rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      let email = request.auth.token.email;
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        email == 'yfjcenter@gmail.com' || 
        email == 'yfj@example.com' || 
        email == 'admin@example.com'
      );
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && (
        membersMap.get(request.auth.uid, null) != null
      );
    }

    // --- Global Collection Group Rules ---
    // These authorize collectionGroup() queries database-wide.
    // They must be defined at the root to match collections at any depth.

    match /{allPaths=**}/preaching_events/{eventId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**}/fines/{fineId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**}/votes/{voteId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Root Collections ---

    match /users/{userId} {
      allow get, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == participantId ||
        isAdmin() ||
        (resource.data.get('userId', null) == null && request.auth.token.email == resource.data.get('email', ''))
      );
      allow delete: if isAdmin();
    }

    match /session_configurations/{configId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isMember(resource.data.get('members', {})) || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /sessions/{sessionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isMember(resource.data.get('members', {})) || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());

      // Nested sub-collection matches (redundant due to collection group rules above but kept for clarity)
      match /preaching_events/{eventId} {
        allow read, write: if isSignedIn();
      }
      match /fines/{fineId} {
        allow read, write: if isSignedIn();
      }
      match /votes/{voteId} {
        allow read, write: if isSignedIn();
      }
    }

    match /roles_admin/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}