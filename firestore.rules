
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return isSignedIn() && resource != null && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'yfjcenter@gmail.com' ||
        request.auth.token.email == 'yfj@example.com' ||
        request.auth.token.email == 'admin@example.com'
      );
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && (
        membersMap[request.auth.uid] != null || 
        membersMap.get(request.auth.uid, null) != null
      );
    }

    // --- Collection Group Rules ---
    // These authorize queries that span across all session sub-collections (collectionGroup queries).
    // They MUST be defined with recursive wildcards to be effective.
    
    match /{path=**}/preaching_events/{eventId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{path=**}/fines/{fineId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{path=**}/votes/{voteId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Standard Collections ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
    }

    match /participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == participantId ||
        isAdmin() ||
        (resource.data.get('userId', null) == null && request.auth.token.email == resource.data.get('email', ''))
      );
      allow delete: if isAdmin();
    }

    match /session_configurations/{configId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isExistingOwner(resource.data.ownerId) || isAdmin();
    }

    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isExistingOwner(resource.data.ownerId) || isMember(resource.data.get('members', {})) || isAdmin();
      allow delete: if isExistingOwner(resource.data.ownerId) || isAdmin();
    }

    match /sessions/{sessionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isMember(resource.data.get('members', {})) || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if isExistingOwner(resource.data.ownerId) || isAdmin();
      
      // Direct subcollection access (e.g. within a specific session view)
      match /preaching_events/{eventId} {
        allow read, create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
      match /fines/{fineId} {
        allow read, create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
      match /votes/{voteId} {
        allow read, create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
