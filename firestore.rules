
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return isSignedIn() && resource != null && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && membersMap[request.auth.uid] != null;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
    }

    match /participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(participantId);
      allow update: if isExistingOwner(participantId);
    }

    match /session_configurations/{configId} {
      allow get, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /groups/{groupId} {
      // Allow all signed-in users to list/get groups so session owners can identify winners
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId) || isMember(resource.data.members);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    match /sessions/{sessionId} {
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isMember(resource.data.members));
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);

      match /preaching_events/{eventId} {
        allow get, list: if isSignedIn() && (resource.data.sessionOwnerId == request.auth.uid || isMember(resource.data.sessionMembers));
        allow create: if isSignedIn();
        allow update, delete: if isExistingOwner(resource.data.sessionOwnerId);
      }

      match /fines/{fineId} {
        allow get, list: if isSignedIn() && (resource.data.sessionOwnerId == request.auth.uid || isMember(resource.data.sessionMembers));
        allow create: if isSignedIn();
        allow update, delete: if isExistingOwner(resource.data.sessionOwnerId);
      }

      match /votes/{voteId} {
        allow get, list: if isSignedIn() && (resource.data.sessionOwnerId == request.auth.uid || isMember(resource.data.sessionMembers));
        allow create: if isSignedIn();
        allow update, delete: if isExistingOwner(resource.data.sessionOwnerId);
      }
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin();
    }
  }
}
