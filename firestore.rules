
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Universal access for authenticated users as requested.
    // This allows both admins and regular users to access sessions, groups, and events.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow collectionGroup queries for preaching_events.
    // This is required even with a global wildcard for collectionGroup queries to be authorized.
    match /{path=**}/preaching_events/{eventId} {
      allow read, write: if request.auth != null;
    }
    
    // Explicitly allow collectionGroup queries for votes.
    match /{path=**}/votes/{voteId} {
      allow read, write: if request.auth != null;
    }
  }
}
