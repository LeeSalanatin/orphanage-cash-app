
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Grant universal access to all authenticated users for all collections and collection groups
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow collection group queries for preaching_events and votes
    // This ensures that collectionGroup queries are not blocked by implicit path requirements.
    match /{path=**}/preaching_events/{event} {
      allow read: if request.auth != null;
    }
    
    match /{path=**}/votes/{vote} {
      allow read: if request.auth != null;
    }
  }
}
