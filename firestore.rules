
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Grant universal access to authenticated users as requested
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow collection group queries for aggregation and dashboard feeds
    match /{path=**}/preaching_events/{event} {
      allow read, list: if request.auth != null;
    }
    
    match /{path=**}/votes/{vote} {
      allow read, list: if request.auth != null;
    }
  }
}
