
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Universal read access for all authenticated users to all documents and collection groups.
    // This supports global dashboard visibility and cross-session historical aggregation.
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
