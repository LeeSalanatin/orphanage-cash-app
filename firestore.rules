rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email in ['yfjcenter@gmail.com', 'yfj@example.com', 'admin@example.com']
      );
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && (
        membersMap.get(request.auth.uid, null) != null
      );
    }

    // --- Global Collection Group Rules ---
    // These rules are required for collectionGroup() queries to work database-wide.
    // They must use recursive wildcards {allPaths=**} at the root.

    match /{allPaths=**}/preaching_events/{eventId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**}/fines/{fineId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**}/votes/{voteId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Root Collections ---

    match /users/{userId} {
      allow get, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == participantId ||
        isAdmin() ||
        (resource.data.get('userId', null) == null && request.auth.token.email == resource.data.get('email', ''))
      );
      allow delete: if isAdmin();
    }

    match /session_configurations/{configId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if (resource != null && request.auth.uid == resource.data.ownerId) || isAdmin();
    }

    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if (resource != null && (request.auth.uid == resource.data.ownerId || isMember(resource.data.get('members', {})))) || isAdmin();
      allow delete: if (resource != null && request.auth.uid == resource.data.ownerId) || isAdmin();
    }

    match /sessions/{sessionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isMember(resource.data.get('members', {})) || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if (resource != null && request.auth.uid == resource.data.ownerId) || isAdmin();

      // Explicit nested matches for direct sub-collection access
      match /preaching_events/{eventId} {
        allow read, write: if isSignedIn();
      }
      match /fines/{fineId} {
        allow read, write: if isSignedIn();
      }
      match /votes/{voteId} {
        allow read, write: if isSignedIn();
      }
    }

    match /roles_admin/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}