rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'yfjcenter@gmail.com' || 
        request.auth.token.email == 'yfj@example.com' || 
        request.auth.token.email == 'admin@example.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && (
        membersMap.get(request.auth.uid, null) != null
      );
    }

    // --- Collection Group Rules (MUST BE AT ROOT LEVEL) ---
    // These authorize queries like firestore.collectionGroup('preaching_events')
    // across the entire database.

    match /{anyPath=**}/preaching_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{anyPath=**}/fines/{fineId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{anyPath=**}/votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Root Collections ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        isAdmin() ||
        (resource.data.get('userId', null) == null && request.auth.token.email == resource.data.get('email', ''))
      );
      allow delete: if isAdmin();
    }

    match /session_configurations/{configId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isMember(resource.data.get('members', {})) || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /sessions/{sessionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isMember(resource.data.get('members', {})) || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());

      // Explicit nested subcollection rules for direct path access
      match /preaching_events/{eventId} {
        allow read, write: if isSignedIn();
      }
      match /fines/{fineId} {
        allow read, write: if isSignedIn();
      }
      match /votes/{voteId} {
        allow read, write: if isSignedIn();
      }
    }

    match /roles_admin/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}