
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard document rules
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit authorization for collection group queries
    // This is required for listing records across all sessions
    match /preaching_events/{event} {
      allow read, write: if request.auth != null;
    }

    match /votes/{vote} {
      allow read, write: if request.auth != null;
    }
    
    match /session_configurations/{config} {
      allow read, write: if request.auth != null;
    }
  }
}
