{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["id", "email", "fullName", "isAdmin"]
    },
    "Participant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Participant",
      "type": "object",
      "description": "Represents an individual who can participate in preaching sessions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "totalPoints": { "type": "number" },
        "totalFines": { "type": "number" }
      },
      "required": ["id", "dateJoined", "email"]
    },
    "Group": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "totalPoints": { "type": "number" },
        "totalFines": { "type": "number" },
        "members": { "type": "object" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Session": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "sessionType": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "object" },
        "votingClosed": { "type": "boolean" },
        "rewardsDistributed": { "type": "boolean" },
        "sessionDate": { "type": "string" },
        "maxPreachingTimeMinutes": { "type": "number" },
        "maxPreachingTimeSeconds": { "type": "number" },
        "fineRules": { "type": "array" },
        "votingConfig": { "type": "object" },
        "pointDistribution": { "type": "object" }
      },
      "required": ["id", "title", "status", "ownerId"]
    },
    "PreachingEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PreachingEvent",
      "type": "object",
      "description": "Records the details of a single preaching event within a session.",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "participantId": { "type": "string" },
        "participantName": { "type": "string" },
        "preachingGroupId": { "type": "string" },
        "actualDurationSeconds": { "type": "number" },
        "actualDurationFormatted": { "type": "string" },
        "overageSeconds": { "type": "number" },
        "totalFineAmount": { "type": "number" },
        "explanation": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "sessionMembers": { "type": "object" },
        "sessionOwnerId": { "type": "string" }
      },
      "required": ["id", "sessionId", "actualDurationSeconds", "sessionMembers"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "participants/{participantId}": {
      "schema": "Participant",
      "description": "Stores participant-specific data."
    },
    "groups/{groupId}": {
      "schema": "Group",
      "description": "Manages groups of participants."
    },
    "sessions/{sessionId}": {
      "schema": "Session",
      "description": "Represents an instance of a preaching session."
    },
    "sessions/{sessionId}/preaching_events/{preachingEventId}": {
      "schema": "PreachingEvent",
      "description": "Records individual preaching events within a session."
    },
    "session_configurations/{configId}": {
      "schema": "object",
      "description": "Reusable session configuration templates."
    }
  }
}
