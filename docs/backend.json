{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["id", "email", "fullName", "isAdmin"]
    },
    "Participant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Participant",
      "type": "object",
      "description": "Represents an individual who can participate in preaching sessions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preachingNickname": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "totalPoints": { "type": "number" },
        "totalFines": { "type": "number" }
      },
      "required": ["id", "dateJoined"]
    },
    "Group": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "totalPoints": { "type": "number" },
        "totalFines": { "type": "number" },
        "members": { "type": "object" }
      },
      "required": ["id", "name"]
    },
    "Session": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "sessionType": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "object" }
      },
      "required": ["id", "title", "status", "ownerId"]
    },
    "PreachingEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PreachingEvent",
      "type": "object",
      "description": "Records the details of a single preaching event within a session.",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "participantId": { "type": "string" },
        "participantName": { "type": "string" },
        "preachingGroupId": { "type": "string" },
        "actualDurationSeconds": { "type": "number" },
        "actualDurationFormatted": { "type": "string" },
        "overageSeconds": { "type": "number" },
        "totalFineAmount": { "type": "number" },
        "explanation": { "type": "string" },
        "sessionMembers": { "type": "object" }
      },
      "required": ["id", "sessionId", "actualDurationSeconds", "sessionMembers"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/participants/{participantId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Participant" },
          "description": "Stores participant-specific data."
        }
      },
      {
        "path": "/groups/{groupId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Group" },
          "description": "Manages groups of participants."
        }
      },
      {
        "path": "/sessions/{sessionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Session" },
          "description": "Represents an instance of a preaching session."
        }
      },
      {
        "path": "/sessions/{sessionId}/preaching_events/{preachingEventId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/PreachingEvent" },
          "description": "Records individual preaching events within a session."
        }
      }
    ]
  }
}